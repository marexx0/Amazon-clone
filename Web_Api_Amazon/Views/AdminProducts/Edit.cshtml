@model Web_Api_Amazon.Entities.Product
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<div class="container mt-4">
    <h2>Edit Product</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">

        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Price"></label>
            <input asp-for="Price" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>Category</label>
            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
            </select>
        </div>

        <!-- Images -->
        <div class="form-group mb-3">
            <label>Upload New Images</label>
            <input type="file" name="ImagesFiles" multiple class="form-control" />
        </div>

        <!-- Existing Properties -->
        <div class="form-group mb-3">
            <label>Properties</label>
            <div id="propertiesContainer">
                @if (Model.Properties != null)
                {
                    for (int i = 0; i < Model.Properties.Count; i++)
                    {
                        var propertyName = Model.Properties[i].Name ?? Model.Properties[i].PropertyDefinition?.Name ?? string.Empty;
                        <div class="d-flex mb-2">
                            <input type="text" name="Properties[@i].Name"
                                   value="@propertyName"
                                   class="form-control me-2" />

                            <input type="text" name="Properties[@i].Value"
                                   value="@Model.Properties[i].Value"
                                   class="form-control me-2" />

                            <button type="button" class="btn btn-danger btn-sm removeProperty">X</button>
                        </div>
                    }
                }
            </div>
            <button type="button" id="addProperty" class="btn btn-primary btn-sm mt-2">
                Add Property
            </button>
        </div>

        <!-- Existing Variants -->
        <div class="form-group mb-3">
            <label>Variants</label>
            <div id="variantsContainer">
                @if (Model.Variants != null)
                {
                    for (int i = 0; i < Model.Variants.Count; i++)
                    {
                        var fallbackVariantValue = Model.Variants[i].VariantValues?.FirstOrDefault();
                        var variantName = Model.Variants[i].Name ?? fallbackVariantValue?.PropertyDefinition?.Name ?? string.Empty;
                        var variantValue = Model.Variants[i].Value ?? fallbackVariantValue?.Value ?? string.Empty;
                        <div class="d-flex mb-2">
                            <input type="text" name="Variants[@i].Name"
                                   value="@variantName"
                                   class="form-control me-2" />

                            <input type="text" name="Variants[@i].Value"
                                   value="@variantValue"
                                   class="form-control me-2" />

                            <button type="button" class="btn btn-danger btn-sm removeVariant">X</button>
                        </div>
                    }
                }
            </div>
            <button type="button" id="addVariant" class="btn btn-primary btn-sm mt-2">
                Add Variant
            </button>
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        let propertyIndex = @(Model.Properties?.Count ?? 0);
        let variantIndex = @(Model.Variants?.Count ?? 0);

        document.getElementById('addProperty').addEventListener('click', function () {
            const container = document.getElementById('propertiesContainer');
            const div = document.createElement('div');
            div.classList.add('d-flex', 'mb-2');
            div.innerHTML = `
                <input type="text" name="Properties[${propertyIndex}].Name" class="form-control me-2" placeholder="Property Name" />
                <input type="text" name="Properties[${propertyIndex}].Value" class="form-control me-2" placeholder="Property Value" />
                <button type="button" class="btn btn-danger btn-sm removeProperty">X</button>
            `;
            container.appendChild(div);
            propertyIndex++;
        });

        document.getElementById('addVariant').addEventListener('click', function () {
            const container = document.getElementById('variantsContainer');
            const div = document.createElement('div');
            div.classList.add('d-flex', 'mb-2');
            div.innerHTML = `
                <input type="text" name="Variants[${variantIndex}].Name" class="form-control me-2" placeholder="Variant Name" />
                <input type="text" name="Variants[${variantIndex}].Value" class="form-control me-2" placeholder="Variant Value" />
                <button type="button" class="btn btn-danger btn-sm removeVariant">X</button>
            `;
            container.appendChild(div);
            variantIndex++;
        });
        document.getElementById('propertiesContainer').addEventListener('click', function (e) {
            if (e.target.classList.contains('removeProperty')) {
                e.target.parentElement.remove();
            }
        });

        document.getElementById('variantsContainer').addEventListener('click', function (e) {
            if (e.target.classList.contains('removeVariant')) {
                e.target.parentElement.remove();
            }
        });
    </script>
}