@using Web_Api_Amazon.Entities
@model IEnumerable<Web_Api_Amazon.Entities.Product>
@{
    var allProducts = ViewBag.AllProducts as List<Product> ?? new List<Product>();
    var filteredProducts = ViewBag.FilteredProducts as List<Product> ?? new List<Product>();
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;

    List<Product> PickProducts(IEnumerable<Product> source, int take)
    {
        var list = source.ToList();
        if (!list.Any() || take <= 0)
        {
            return new List<Product>();
        }

        if (list.Count <= take)
        {
            return list;
        }

        return list
            .OrderBy(_ => Random.Shared.Next())
            .Take(take)
            .ToList();
    }

    var popularProducts = PickProducts(allProducts, 12);
}
