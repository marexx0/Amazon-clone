        @{
            var selectedCategories = new List<int> { 6, 7, 9 };

            var categoryImages = new Dictionary<int, string>
                {
                {6, "~/imagesmain/cloth3.png"},
                {7, "~/imagesmain/sho6.png"},
                {9, "~/imagesmain/phone2.png"},
                };

            var categories = ViewBag.Categories as List<Category> ?? new List<Category>();

            var categoriesToShow = categories
            .Where(c => selectedCategories.Contains(c.Id))
            .ToList();
        }

        <section class="collection shop-collection">
            <h2>Shop Collection</h2>
            <div class="collection-grid">
                @foreach (var category in categoriesToShow)
                {
                    <a href="/?categoryId=@category.Id" class="category-card">
                        <img src="@Url.Content(categoryImages[category.Id])" alt="@category.Name" />
                        <div class="category-name">@category.Name</div>
                    </a>
                }
            </div>
        </section>
        @{
            var technologyCategoryIds = new List<int> { 8, 9, 10, 11, 12 };

            var technologyProducts = PickProducts(
            allProducts.Where(p => technologyCategoryIds.Contains(p.CategoryId)),
            12);
        }
        
        <!-- Gifts -->
        <section class="collection">
            <h2>Women's Day Gifts</h2>

            <div class="products-grid">
                @foreach (var product in technologyProducts)
                {
                    <partial name="_ProductCard" model="product" />
                }
            </div>
        </section>
