@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Amazon Clone</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #e5e5e5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .main-container {
            width: 100%;
            max-width: 1100px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
            overflow: hidden;
            display: flex;
            min-height: 650px;
        }

        .form-section {
            flex: 0 0 42%;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: white;
        }

        .image-section {
            flex: 1;
            background: linear-gradient(135deg, #e8eaf6 0%, #f3e5f5 100%);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .image-section::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(103, 58, 183, 0.08) 0%, transparent 70%);
                border-radius: 50%;
                animation: pulse 4s ease-in-out infinite;
            }

        .logo {
            position: absolute;
            bottom: 50px;
            right: 50px;
            font-size: 32px;
            font-weight: 700;
            color: #673ab7;
            font-style: italic;
            letter-spacing: -1px;
        }

        h1 {
            font-size: 26px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #6b7280;
            font-size: 14px;
            margin-bottom: 35px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #374151;
            font-size: 13px;
        }

        .input-wrapper {
            position: relative;
        }

        input {
            width: 100%;
            padding: 11px 16px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.2s ease;
            background: #fafafa;
        }

            input:focus {
                outline: none;
                border-color: #673ab7;
                background: white;
                box-shadow: 0 0 0 3px rgba(103, 58, 183, 0.08);
            }

            input::placeholder {
                color: #b0b0b0;
            }

        .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #9ca3af;
            font-size: 18px;
            user-select: none;
        }

        .validation-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 6px;
            display: block;
        }

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #673ab7;
            color: white;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-top: 10px;
            margin-bottom: 20px;
        }

            .btn-login:hover {
                background: #5e35b1;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(103, 58, 183, 0.3);
            }

            .btn-login:active {
                transform: scale(0.98);
            }

        .divider {
            text-align: center;
            color: #9ca3af;
            font-size: 12px;
            margin: 22px 0;
        }

        .oauth-buttons {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 28px;
        }

        .oauth-button {
            width: 100%;
            padding: 11px;
            border-radius: 8px;
            border: 1.5px solid #e0e0e0;
            background: white;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            color: #374151;
        }

            .oauth-button:hover {
                background: #fafafa;
                border-color: #c0c0c0;
                transform: translateY(-1px);
            }

            .oauth-button img {
                width: 18px;
                height: 18px;
                margin-right: 10px;
            }

        .links {
            text-align: left;
            font-size: 13px;
            color: #6b7280;
            line-height: 2;
        }

            .links a {
                color: #1a1a1a;
                text-decoration: none;
                font-weight: 500;
            }

                .links a:hover {
                    text-decoration: underline;
                }

        .footer {
            text-align: left;
            margin-top: 40px;
            padding-top: 25px;
            border-top: 1px solid #f0f0f0;
            font-size: 11px;
            color: #9ca3af;
        }


        50% {
            transform: scale(1.1);
            opacity: 0.3;
        }

        }
    </style>
</head>
<body>
    <div class="main-container">
        <div class="form-section">
            <div>
                <h1>Log In to Allora</h1>
                <p class="subtitle">Welcome back. Sign in to continue your journey</p>

                <!-- Login form -->
                <form asp-action="Login" asp-controller="Account" method="post">
                    <div class="input-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" type="email" placeholder="name@gmail.com" />
                        <span asp-validation-for="Email" class="validation-error"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="Password">Password</label>
                        <div class="input-wrapper">
                            <input asp-for="Password" type="password" placeholder="••••••••" id="passwordInput" />
                            <span class="password-toggle" onclick="togglePassword()">👁</span>
                        </div>
                        <span asp-validation-for="Password" class="validation-error"></span>
                    </div>

                    <button type="submit" class="btn-login">Log In</button>
                </form>

                <div class="divider">
                    Make sure you're using the email you signed up with
                </div>

                <!-- OAuth buttons -->
                <div class="oauth-buttons">
                    <button type="button" class="oauth-button">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="Google" />
                        Continue with Google
                    </button>
                    <button type="button" class="oauth-button">
                        <img src="https://upload.wikimedia.org/wikipedia/commons/f/fa/Apple_logo_black.svg" alt="Apple" />
                        Continue with Apple
                    </button>
                </div>

                <div class="links">
                    New to Allora? <a asp-action="Register" asp-controller="Account">Create an account</a><br />
                    <a href="#">Forget Password?</a>
                </div>

                <div class="footer">
                    © 2028, Allora.com, Inc. or its affiliates
                </div>
            </div>
        </div>

        <div class="image-section">
            <div class="logo">allora</div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const toggle = event.target;
            if (input.type === 'password') {
                input.type = 'text';
                toggle.textContent = '🙈';
            } else {
                input.type = 'password';
                toggle.textContent = '👁';
            }
        }
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>