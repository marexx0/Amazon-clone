@model LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Login";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">


    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "DM Sans", sans-serif;
            background: #FCFCFC;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

      


        /* ===== Layout ===== */

        .main-container {
            width: 100%;
            max-width: 1440px;
            grid-template-columns: 420px 1fr;
            gap: 80px;
            display: grid;
           
            
        }

        .main-container {
            max-width: 1440px;
            grid-template-columns: 420px 1fr;
            gap: 80px;
        }

        /* ===== LEFT ===== */

        .form-section {
            max-width: 420px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        h1 {
            font-family: "DM Sans", sans-serif;
            font-size: 28px; 
            line-height: 36px;
            font-weight: 700;
            color: #080808; 
            margin-bottom: 8px;
        }


        .subtitle {
            font-family: "DM Sans", sans-serif;
            font-size: 14px; 
            line-height: 24px;
            font-weight: 500;
            color: #686868; 
            margin-bottom: 28px;
        }


        .input-group {
            margin-bottom: 18px;
        }

        label {
            font-size: 12px;
            margin-bottom: 6px;
            display: block;
        }

        input {
            width: 100%;
            height: 44px;
            padding: 0 14px;
            border: 1px solid #E5E5E5;
            border-radius: 8px;
            font-size: 14px;
            background: white;
        }

            input:focus {
                outline: none;
                border-color: #CFCFCF;
            }

        .password-group {
            position: relative;
        }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 38px;
            cursor: pointer;
            color: #808080;
        }

        .validation-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
            display: block;
        }

        .btn-login {
            width: 100%;
            height: 44px;
            border: none;
            border-radius: 8px;
            background: #E5E5E5;
            color: #080808;
            font-weight: 500;
            margin-top: 8px;
            cursor: pointer;
        }

        .hint {
            font-size: 12px;
            color: #808080;
            margin: 14px 0 18px;
        }

        .oauth-buttons {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 22px;
        }

        .oauth-button {
            height: 44px;
            border-radius: 10px;
            background: #EEF4FD; 
            border: 1px solid #DDE7FA; 

            font-family: "DM Sans", sans-serif;
            font-size: 14px;
            font-weight: 500;
            color: #0D1B34; 

            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            cursor: pointer;
            transition: background 0.15s ease, border-color 0.15s ease;
            text-decoration: none;
        }


            .oauth-button:hover {
                background: #DDE7FA; 
            }

            .oauth-button:active {
                background: #B4CFF5; 
            }


            .oauth-button i {
                font-size: 16px;
            }


        .links {
            font-size: 13px;
            line-height: 1.8;
        }

            .links a {
                color: #080808;
                font-weight: 500;
                text-decoration: none;
            }

        /* FOOTER LINKS */

       
        .footer-links {
            margin-top: 24px;
            font-size: 13px;
            line-height: 1.8;
            color: #6B7280;
        }

        .link-primary {
            color: #1D64CC;
            font-weight: 500;
            text-decoration: none;
        }

            .link-primary:hover {
                text-decoration: underline;
            }

        .link-muted {
            color: #878787;
            font-weight: 500;
            text-decoration: none;
        }

            .link-muted:hover {
                text-decoration: underline;
            }

        .footer {
            margin-top: 40px;
            font-size: 11px;
            color: #9CA3AF;
        }

        /* ===== RIGHT ===== */
        .oauth-button {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

     .image-section {
    position: relative;
    background: #0D1B34;
    border-radius: 24px;
    overflow: hidden;

    
    min-width: 220px;
    min-height: 620px; 
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 60%;
    max-height: 60%;
    width: auto;
    height: auto;
}

.logo-small {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 104px;
    height: 61px;
    object-fit: contain;
    opacity: 1;
}




        /* ===== Responsive ===== */

        @@media (max-width:900px) {
            .main-container {
                grid-template-columns: 1fr;
                max-width: 520px;
            }

            .image-section {
                min-height: 320px;
            }
        }
    </style>
</head>

<body>

    <div class="main-container">

        <!-- LEFT -->
        <div class="form-section">

            <h1>Welcome to Allora!</h1>
            <div class="subtitle">
               Choose how you'd like to continue
            </div>

       

           

            <div class="oauth-buttons">

                <a asp-controller="Account" asp-action="Login" class="oauth-button">
                    <i class="fa-brands fa-google"></i>
                    Continue with Google
                </a>

                <a asp-controller="Account" asp-action="Login" class="oauth-button">
                    <i class="fa-brands fa-apple"></i>
                    Continue with Apple
                </a>

            </div>


           
            <div class="footer-links">
                New to Allora?
                <a asp-action="SelectAccountType" asp-controller="Account" class="link-primary">Create an account</a><br />

                Already have an account?
                <a asp-action="Login" asp-controller="Account" class="link-primary">Log in</a><br />

                <a asp-action="Index" asp-controller="Home" class="link-muted">
                    ← Return to Previous Page
                </a>
            </div>

            <div class="footer">
                © 2026 Allora.com Inc. or its affiliates
            </div>

        </div>

        <!-- RIGHT -->
         <div class="image-section">
    <img src="~/imageslogreg/Illustrations1.png" asp-append-version="true" class="auth-image" />
    <img src="~/imageslogreg/Logotype.png" asp-append-version="true" class="logo-small" />
</div>

    </div>

    @section Scripts{
        <partial name="_ValidationScriptsPartial" />
    }
    <script>
        function togglePassword() {
            const input = document.getElementById("passwordInput");
            const icon = document.getElementById("eyeIcon");

            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }
    </script>

</body>
</html>



