@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register - Amazon Clone</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #e5e5e5;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .page-title {
            position: absolute;
            top: 30px;
            left: 50%;
            transform: translateX(-50%);
            color: #9ca3af;
            font-size: 14px;
            font-weight: 500;
        }

        .main-container {
            width: 100%;
            max-width: 1100px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
            overflow: hidden;
            display: flex;
            min-height: 650px;
        }

        .form-section {
            flex: 0 0 42%;
            padding: 60px 50px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: white;
        }

        .image-section {
            flex: 1;
            background: linear-gradient(135deg, #e8eaf6 0%, #f3e5f5 100%);
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .image-section::before {
                content: '';
                position: absolute;
                width: 400px;
                height: 400px;
                background: radial-gradient(circle, rgba(103, 58, 183, 0.08) 0%, transparent 70%);
                border-radius: 50%;
                animation: pulse 4s ease-in-out infinite;
            }

        .logo {
            position: absolute;
            bottom: 50px;
            right: 50px;
            font-size: 32px;
            font-weight: 700;
            color: #673ab7;
            font-style: italic;
            letter-spacing: -1px;
        }

        .progress-bar {
            width: 50px;
            height: 3px;
            background: #673ab7;
            margin-bottom: 25px;
        }

        h1 {
            font-size: 24px;
            font-weight: 600;
            color: #1a1a1a;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #6b7280;
            font-size: 13px;
            margin-bottom: 30px;
        }

        .input-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
            color: #374151;
            font-size: 13px;
        }

        .input-wrapper {
            position: relative;
        }

        input[type="text"],
        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 11px 16px;
            border: 1.5px solid #e0e0e0;
            border-radius: 8px;
            font-size: 14px;
            transition: all 0.2s ease;
            background: #fafafa;
        }

        input:focus {
            outline: none;
            border-color: #673ab7;
            background: white;
            box-shadow: 0 0 0 3px rgba(103, 58, 183, 0.08);
        }

        input::placeholder {
            color: #b0b0b0;
        }

        .password-toggle {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #9ca3af;
            font-size: 18px;
            user-select: none;
        }

        .password-requirements {
            display: flex;
            gap: 12px;
            margin-top: 8px;
            font-size: 11px;
            color: #9ca3af;
        }

        .requirement {
            padding: 4px 8px;
            background: #f5f5f5;
            border-radius: 4px;
        }

        .char-count {
            font-size: 11px;
            color: #9ca3af;
            margin-top: 5px;
        }

        .validation-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 6px;
            display: block;
        }

        .btn-continue {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 8px;
            background: #673ab7;
            color: white;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.2s ease;
            margin-top: 15px;
            margin-bottom: 20px;
        }

            .btn-continue:hover {
                background: #5e35b1;
                transform: translateY(-1px);
                box-shadow: 0 4px 12px rgba(103, 58, 183, 0.3);
            }

            .btn-continue:active {
                transform: scale(0.98);
            }

        .checkbox-group {
            margin-bottom: 12px;
        }

        .checkbox-wrapper {
            display: flex;
            align-items: center;
            font-size: 13px;
            color: #374151;
            margin-bottom: 8px;
        }

            .checkbox-wrapper input[type="checkbox"] {
                width: 16px;
                height: 16px;
                margin-right: 8px;
                cursor: pointer;
            }

            .checkbox-wrapper a {
                color: #1a1a1a;
                font-weight: 600;
                text-decoration: none;
            }

                .checkbox-wrapper a:hover {
                    text-decoration: underline;
                }

        .back-link {
            display: inline-block;
            font-size: 13px;
            color: #1a1a1a;
            text-decoration: none;
            font-weight: 500;
            margin-top: 10px;
        }

            .back-link:hover {
                text-decoration: underline;
            }

        .footer {
            text-align: left;
            margin-top: 30px;
            padding-top: 25px;
            border-top: 1px solid #f0f0f0;
            font-size: 11px;
            color: #9ca3af;
        }

    </style>
</head>
<body>
    <div class="page-title">Personal Registration</div>

    <div class="main-container">
        <div class="form-section">
            <div>
                <div class="progress-bar"></div>

                <h1>Create your personal account</h1>
                <p class="subtitle">Join Allora and make smarter choices with ease</p>

                <!-- Registration form -->
                <form asp-action="Register" asp-controller="Account" method="post">
                    <div class="input-group">
                        <label asp-for="Email">Email</label>
                        <input asp-for="Email" type="email" placeholder="name@gmail.com" />
                        <span asp-validation-for="Email" class="validation-error"></span>
                    </div>

                    <div class="input-group">
                        <label asp-for="Password">Password</label>
                        <div class="input-wrapper">
                            <input asp-for="Password" type="password" placeholder="••••••••" id="passwordInput" />
                            <span class="password-toggle" onclick="togglePassword()">👁</span>
                        </div>
                        <div class="password-requirements">
                            <span class="requirement">Number</span>
                            <span class="requirement">Uppercase Letter</span>
                            <span class="requirement">Lowercase Letter</span>
                        </div>
                        <span asp-validation-for="Password" class="validation-error"></span>
                    </div>

                
                    <button type="submit" class="btn-continue">Continue</button>

                    <div class="checkbox-group">
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="terms" required />
                            <label for="terms" style="display: inline; margin: 0; font-weight: 400;">
                                I agree to the <a href="#">Terms of Service</a>
                            </label>
                        </div>
                        <div class="checkbox-wrapper">
                            <input type="checkbox" id="privacy" required />
                            <label for="privacy" style="display: inline; margin: 0; font-weight: 400;">
                                I agree to the <a href="#">Privacy Policy</a>
                            </label>
                        </div>
                    </div>

                    <a asp-action="Login" asp-controller="Account" class="back-link">Return to Previous Page</a>
                </form>

                <div class="footer">
                    © 2028, Allora.com, Inc. or its affiliates
                </div>
            </div>
        </div>

        <div class="image-section">
            <div class="logo">allora</div>
        </div>
    </div>

    <script>
        function togglePassword() {
            const input = document.getElementById('passwordInput');
            const toggle = event.target;
            if (input.type === 'password') {
                input.type = 'text';
                toggle.textContent = '🙈';
            } else {
                input.type = 'password';
                toggle.textContent = '👁';
            }
        }
    </script>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
    }
</body>
</html>