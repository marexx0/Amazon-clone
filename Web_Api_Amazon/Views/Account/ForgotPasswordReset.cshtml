@model ForgotPasswordResetViewModel

@{
    Layout = null;
    ViewData["Title"] = "Reset Password";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Reset Password</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "DM Sans", sans-serif;
            background: #FCFCFC;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 40px;
        }

        .main-container {
            width: 100%;
            max-width: 1400px;
            display: grid;
            grid-template-columns: 420px 1fr;
            gap: 60px;
        }

        .form-section {
            max-width: 420px;
        }

        h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #808080;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .input-group {
            margin-bottom: 18px;
        }

        label {
            font-size: 12px;
            margin-bottom: 6px;
            display: block;
        }

        .input-wrapper {
            position: relative;
        }

        input {
            width: 100%;
            height: 44px;
            padding: 0 14px;
            padding-right: 70px;
            border: 1px solid #E5E5E5;
            border-radius: 8px;
            font-size: 14px;
            background: white;
            transition: all 0.2s ease;
        }

            input:focus {
                outline: none;
                border-color: #CFCFCF;
            }

            input.valid {
                border: 1px solid #379838;
                background: #37983833;
            }

            input.invalid {
                border: 1px solid #ef4444;
                background: #ef444422;
            }

        .toggle-password {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            cursor: pointer;
            color: #808080;
        }

        .valid-check {
            position: absolute;
            right: 40px;
            top: 50%;
            transform: translateY(-50%);
            color: #379838;
            font-weight: bold;
            display: none;
        }

        .password-rules {
            margin-top: 10px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

            .password-rules span {
                font-size: 11px;
                padding: 6px 10px;
                border-radius: 20px;
                background: #F3F3F3;
                color: #9CA3AF;
                border: 1px solid transparent;
                transition: all 0.2s ease;
            }

                .password-rules span.valid {
                    background: #37983833;
                    border: 1px solid #379838;
                    color: #111827;
                }

        .validation-error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 4px;
        }

        .btn-main {
            width: 100%;
            height: 42px;
            border: none;
            border-radius: 8px;
            background: #CFFA4E;
            font-weight: 700;
            cursor: pointer;
            margin-top: 10px;
        }

            .btn-main:hover {
                background: #B5ED24;
            }

        .image-section {
    position: relative;
    background: #0D1B34;
    border-radius: 24px;
    overflow: hidden;

    
    min-width: 220px;
    min-height: 620px; 
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 60%;
    max-height: 60%;
    width: auto;
    height: auto;
}

.logo-small {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 104px;
    height: 61px;
    object-fit: contain;
    opacity: 1;
}

    </style>
</head>
<body>

    <div class="main-container">

        <div class="form-section">
            <h1>Create a new password</h1>
            <p class="subtitle">Choose a strong password you haven't used before</p>

            <form asp-action="ForgotPasswordReset" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />

                <!-- NEW PASSWORD -->
                <div class="input-group">
                    <label asp-for="Password">New password</label>

                    <div class="input-wrapper">
                        <input type="password"
                               id="passwordInput"
                               asp-for="Password"
                               placeholder="••••••••"
                               oninput="checkPassword()" />

                        <span class="valid-check" id="passwordCheck">✔</span>

                        <span class="toggle-password" onclick="togglePassword()">
                            <i id="eyeIcon" class="fa-regular fa-eye"></i>
                        </span>
                    </div>

                    <span asp-validation-for="Password" class="validation-error"></span>

                    <div class="password-rules">
                        <span id="ruleNumber">Number</span>
                        <span id="ruleUpper">Uppercase</span>
                        <span id="ruleLower">Lowercase</span>
                        <span id="ruleLength">8+ characters</span>
                    </div>
                </div>

                <!-- CONFIRM PASSWORD -->
                <div class="input-group">
                    <label asp-for="ConfirmPassword">Confirm password</label>

                    <div class="input-wrapper">
                        <input type="password"
                               id="confirmPasswordInput"
                               asp-for="ConfirmPassword"
                               placeholder="••••••••"
                               oninput="checkConfirmPassword()" />
                    </div>

                    <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
                </div>

                <button type="submit" class="btn-main">
                    Update password
                </button>

            </form>
        </div>

        <div class="image-section">
    <img src="~/imageslogreg/Group1.png" asp-append-version="true" class="auth-image" />
    <img src="~/imageslogreg/Logotype.png" asp-append-version="true" class="logo-small" />
</div>

    </div>

    <script>

        function togglePassword(){
            const input = document.getElementById("passwordInput");
            const icon = document.getElementById("eyeIcon");

            if(input.type === "password"){
                input.type = "text";
                icon.classList.replace("fa-eye","fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.replace("fa-eye-slash","fa-eye");
            }
        }

        function checkPassword(){
            const passInput = document.getElementById("passwordInput");
            const pass = passInput.value;

            const number = /[0-9]/.test(pass);
            const upper = /[A-Z]/.test(pass);
            const lower = /[a-z]/.test(pass);
            const length = pass.length >= 8;

            toggleRule("ruleNumber", number);
            toggleRule("ruleUpper", upper);
            toggleRule("ruleLower", lower);
            toggleRule("ruleLength", length);

            if(number && upper && lower && length){
                passInput.classList.add("valid");
                passInput.classList.remove("invalid");
                document.getElementById("passwordCheck").style.display = "inline";
            } else {
                passInput.classList.remove("valid");
                passInput.classList.add("invalid");
                document.getElementById("passwordCheck").style.display = "none";
            }

            checkConfirmPassword();
        }

        function toggleRule(id, isValid){
            const el = document.getElementById(id);
            if(isValid) el.classList.add("valid");
            else el.classList.remove("valid");
        }

        function checkConfirmPassword(){
            const pass = document.getElementById("passwordInput").value;
            const confirmInput = document.getElementById("confirmPasswordInput");
            const confirm = confirmInput.value;

            if(confirm.length === 0){
                confirmInput.classList.remove("valid","invalid");
                return;
            }

            if(pass === confirm){
                confirmInput.classList.add("valid");
                confirmInput.classList.remove("invalid");
            } else {
                confirmInput.classList.add("invalid");
                confirmInput.classList.remove("valid");
            }
        }

    </script>

</body>
</html>
