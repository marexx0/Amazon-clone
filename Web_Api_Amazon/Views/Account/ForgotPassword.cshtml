
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}

<div class="account-page">
    <div class="main-container">

        <div class="form-section">
            <h1>Forgot your password?</h1>
            <p class="subtitle">Enter your email to receive a password reset link</p>

            <form asp-action="ForgotPassword" method="post">
                <div class="input-group">
                    <label>Email</label>
                    <input type="email" name="email" placeholder="example@gmail.com" required />
                </div>
                <button type="submit" class="btn-main">Send reset link</button>
            </form>

            <div class="footer-links">
                Remember your password?
                <a asp-controller="Account" asp-action="Login" class="link-primary">Log in</a>
            </div>
        </div>

        <div class="image-section">
            <img src="~/imageslogreg/Illustrations3.png" asp-append-version="true" class="auth-image" />
            <img src="~/imageslogreg/Logotype.png" asp-append-version="true" class="logo-small" />
        </div>
    </div>
</div>

<style>
    @@import url("/css/account-responsive.css");

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: "DM Sans", sans-serif;
        background: #FCFCFC;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px;
    }

    /* ===== Layout ===== */

    .main-container {
        width: 100%;
        max-width: 1400px;
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 60px;
    }

    /* ===== LEFT ===== */

    .form-section {
        max-width: 420px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    h1 {
        font-family: "DM Sans", sans-serif;
        font-size: 28px;
        font-weight: 700;
        margin-bottom: 6px;
        color: #080808;
    }

    .subtitle {
        color: #808080;
        font-size: 14px;
        margin-bottom: 28px;
    }

    .input-group {
        margin-bottom: 18px;
    }

    label {
        font-size: 12px;
        margin-bottom: 6px;
        display: block;
    }

    input {
        width: 100%;
        height: 44px;
        padding: 0 14px;
        border: 1px solid #E5E5E5;
        border-radius: 8px;
        font-size: 14px;
        background: white;
    }

        input:focus {
            outline: none;
            border-color: #CFCFCF;
        }

    .password-group {
        position: relative;
    }

    .toggle-password {
        position: absolute;
        right: 12px;
        top: 38px;
        cursor: pointer;
        color: #808080;
    }

    .validation-error {
        color: #ef4444;
        font-size: 12px;
        margin-top: 4px;
        display: block;
    }

    


    .links {
        font-size: 13px;
        line-height: 1.8;
    }

        .links a {
            color: #080808;
            font-weight: 500;
            text-decoration: none;
        }

    /* BUTTON */
    .btn-main {
        width: 100%;
        height: 42px;
        border: none;
        border-radius: 8px;
        background: #CFFA4E;
        color: #080808;
        font-weight: 700;
        cursor: pointer;
    }

        .btn-main:hover {
            background: #B5ED24;
        }

    /* FOOTER LINKS */
    .footer-links {
        margin-top: 24px;
        font-size: 13px;
        line-height: 1.8;
        color: #6B7280;
    }

    .link-primary {
        color: #1D64CC;
        font-weight: 500;
        text-decoration: none;
    }

        .link-primary:hover {
            text-decoration: underline;
        }

    .link-muted {
        color: #878787;
        font-weight: 500;
        text-decoration: none;
    }

        .link-muted:hover {
            text-decoration: underline;
        }

    .footer {
        margin-top: 40px;
        font-size: 11px;
        color: #9CA3AF;
    }
    /* ===== RIGHT ===== */
    .oauth-button {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }



    .image-section {
    position: relative;
    background: #0D1B34;
    border-radius: 24px;
    overflow: hidden;

 
    min-width: 220px;
    min-height: 620px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.auth-image {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 60%;
    max-height: 60%;
    width: auto;
    height: auto;
}

.logo-small {
    position: absolute;
    bottom: 20px;
    right: 20px;
    width: 104px;
    height: 61px;
    object-fit: contain;
    opacity: 1;
}

    /* ===== Responsive ===== */

    @@media (max-width:900px) {
        .main-container {
            grid-template-columns: 1fr;
            max-width: 520px;
        }

        .image-section {
            min-height: 320px;
        }
    }
</style>