@model Web_Api_Amazon.Models.ShoppingCartViewModel
@{
    ViewData["Title"] = "Shopping cart";
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="cart-page">
    <div class="cart-main">
        <h1 class="cart-title">Shopping cart</h1>

        @if (!Model.IsSignedIn)
        {
            <div class="cart-note">
                Please <a asp-controller="Account" asp-action="Login">sign in</a> to view your cart data.
            </div>
        }
        else if (!Model.CartItems.Any())
        {
            <div class="cart-note">Your cart is empty.</div>
        }
        else
        {
            @foreach (var item in Model.CartItems)
            {
                <article class="cart-item">
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" class="cart-item__image" />
                    }

                    <div class="cart-item__content">
                        <div class="cart-item__head">
                            <h2>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">@item.Name</a>
                            </h2>
                            <strong>@item.TotalPrice.ToString("C")</strong>
                        </div>

                        <p class="stock @(item.InStock ? "is-in" : "is-out")">
                            @(item.InStock ? "In stock" : "Out of stock")
                        </p>

                        <div class="cart-item__meta">Size: <span>@item.Size</span></div>
                        <div class="cart-item__meta">Color: <span>@item.Color</span></div>
                        <div class="cart-item__meta">Quantity: <span>@item.Quantity</span></div>
                    </div>
                </article>
            }
        }

        <section class="saved">
            <div class="section-title">Saved for later (@Model.SavedForLater.Count)</div>

            @if (Model.SavedForLater.Any())
            {
                <div class="card-grid">
                    @foreach (var item in Model.SavedForLater)
                    {
                        <article class="product-card">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" />
                            }
                            <div class="product-card__body">
                                <strong>@item.Price.ToString("C")</strong>
                                <h3>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">@item.Name</a>
                                </h3>
                                <p>@item.Description</p>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="cart-note">No saved products available.</div>
            }
        </section>

        <section class="saved">
            <div class="section-title">Customers also viewed</div>

            @if (Model.Recommendations.Any())
            {
                <div class="card-grid card-grid--recommend">
                    @foreach (var item in Model.Recommendations)
                    {
                        <article class="product-card">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" />
                            }
                            <div class="product-card__body">
                                <strong>@item.Price.ToString("C")</strong>
                                <h3>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">@item.Name</a>
                                </h3>
                                <p>@item.Description</p>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </div>

    <aside class="summary">
        <h3>Order summary</h3>

        @if (Model.CartItems.Any())
        {
            @foreach (var item in Model.CartItems)
            {
                <div class="summary-row">
                    <span>@item.Name</span>
                    <span>@item.TotalPrice.ToString("C")</span>
                </div>
            }

            <hr />
            <div class="summary-row"><span>Subtotal:</span><strong>@Model.Subtotal.ToString("C")</strong></div>
            <div class="summary-row"><span>Shipping:</span><span>@Model.Shipping.ToString("C")</span></div>
            <div class="summary-row total"><span>Total:</span><strong>@Model.Total.ToString("C")</strong></div>
            <button class="checkout" type="button">Proceed to checkout</button>
        }
        else
        {
            <div class="cart-note">No items in order summary.</div>
        }
    </aside>
</div>