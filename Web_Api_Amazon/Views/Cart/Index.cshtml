﻿@using System.Globalization
@using Web_Api_Amazon.Entities
@model Web_Api_Amazon.Models.ShoppingCartViewModel
@{
    ViewData["Title"] = "Shopping cart";
}

@functions {
    private static string FormatUsd(decimal amount)
    {
        return $"${amount.ToString("0.00", CultureInfo.InvariantCulture)}";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/cart.css" asp-append-version="true" />
}

<div class="cart-page-shell">
    <div class="cart-page">
        <div class="cart-main">

        @if (!Model.CartItems.Any())
        {
            <div class="cart-note">Your cart is empty.</div>
        }
        else
        {
            @foreach (var item in Model.CartItems)
            {
                <article class="cart-item">
                    @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Name" class="cart-item__image" />
                    }

                    <div class="cart-item__content">
                        <div class="cart-item__head">
                            <h2>
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId">@item.Name</a>
                            </h2>
                            <strong>@FormatUsd(item.TotalPrice)</strong>
                        </div>

                        <p class="stock @(item.InStock ? "is-in" : "is-out")">
                            @(item.InStock ? "In stock" : "Out of stock")
                        </p>

                        @if (item.Attributes.Any())
                        {
                            @foreach (var attr in item.Attributes)
                            {
                                <div class="cart-item__meta">@attr.Name: <span>@attr.Value</span></div>
                            }
                        }

                        <div class="cart-item__footer">
                            <div class="cart-qty-control" aria-label="Quantity selector">
                                <button type="button" class="cart-qty-btn">−</button>
                                <span class="cart-qty-value">@item.Quantity</span>
                                <button type="button" class="cart-qty-btn">+</button>
                            </div>

                            <div class="cart-item__actions">
                                <form asp-controller="Cart" asp-action="Delete" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="variantKey" value="@item.VariantKey" />
                                    <button class="action-link action-link--danger" type="submit">Delete</button>
                                </form>

                                <span class="action-divider" aria-hidden="true">|</span>
                                <form asp-controller="Cart" asp-action="SaveForLater" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="hidden" name="variantKey" value="@item.VariantKey" />
                                    <button class="action-link" type="submit">Save for later</button>
                                </form>
                                <span class="action-divider" aria-hidden="true">|</span>
                                <button class="action-buy" type="button">Buy it now</button>
                            </div>
                        </div>
                    </div>
                </article>
            }
        }


            <section class="saved" id="saved-favorites-section">
                <div class="saved-tabs" role="tablist" aria-label="Saved items and favorites">
                    <button class="saved-tab is-active"
                            type="button"
                            role="tab"
                            id="saved-tab"
                            aria-selected="true"
                            aria-controls="saved-panel"
                            data-tab-target="saved-panel">
                        Saved for later
                    </button>
                    <button class="saved-tab"
                            type="button"
                            role="tab"
                            id="favorites-tab"
                            aria-selected="false"
                            aria-controls="favorites-panel"
                            data-tab-target="favorites-panel">
                        Favorites
                    </button>
                </div>

                <div class="saved-panel" id="saved-panel" role="tabpanel" aria-labelledby="saved-tab">
                    @if (Model.SavedForLater.Any())
                    {
                        <div class="card-grid">
                            @foreach (var item in Model.SavedForLater)
                            {
                                var productCard = new Product
                                {
                                    Id = item.ProductId,
                                    Name = item.Name,
                                    Description = item.Description,
                                    ImageUrl = item.ImageUrl,
                                    Price = (double)item.Price
                                };
                                <partial name="_ProductCard" model="productCard" />
                            }
                        </div>
                    }
                    else
                    {
                        <div class="saved-empty-state" aria-live="polite">
                            <div class="saved-empty-state__icon" aria-hidden="true"> <img src="~/images/ui/EmptyCart.png" alt="" /> </div>
                            <h3>Save your items for later</h3>
                            <p>If you aren't ready to buy, select Save for later. We'll keep the item safe here.</p>
                        </div>
                    }
                </div>

                <div class="saved-panel" id="favorites-panel" role="tabpanel" aria-labelledby="favorites-tab" hidden>
                    @if (Model.Favorites.Any())
                    {
                        <div class="card-grid">
                            @foreach (var item in Model.Favorites)
                            {
                                var productCard = new Product
                                {
                                    Id = item.ProductId,
                                    Name = item.Name,
                                    Description = item.Description,
                                    ImageUrl = item.ImageUrl,
                                    Price = (double)item.Price
                                };
                                <partial name="_ProductCard" model="productCard" />
                            }
                        </div>
                    }
                    else
                    {
                        <div class="saved-empty-state" aria-live="polite">
                            <div class="saved-empty-state__icon" aria-hidden="true"> <img src="~/images/ui/EmptyCart.png" alt="" /> </div>
                            <h3>No favorites yet</h3>
                            <p>Add products to favorites to see them here.</p>
                        </div>
                    }
                </div>
            </section>

            @if (Model.Recommendations.Any())
            {
                <section class="saved">
                    <div class="section-title">Customers also viewed</div>

                    <div class="card-grid card-grid--recommend">
                        @foreach (var item in Model.Recommendations)
                        {
                            var productCard = new Product
                            {
                                Id = item.ProductId,
                                Name = item.Name,
                                Description = item.Description,
                                ImageUrl = item.ImageUrl,
                                Price = (double)item.Price
                            };
                            <partial name="_ProductCard" model="productCard" />
                        }
                    </div>
                </section>
            }
        </div>

        <aside class="summary-sidebar">
            <section class="summary">
                <h3>Order summary</h3>

                @if (Model.CartItems.Any())
                {
                    @foreach (var item in Model.CartItems)
                    {
                        <div class="summary-row">
                            <span>@item.Name</span>
                            <span>@FormatUsd(item.TotalPrice)</span>
                        </div>
                    }

                    <hr class="summary-separator" />
                    <div class="summary-row"><span>Subtotal:</span><strong>@FormatUsd(Model.Subtotal)</strong></div>
                    <div class="summary-row"><span>Shipping:</span><span>@FormatUsd(Model.Shipping)</span></div>
                    <div class="summary-row total"><span>Total:</span><strong>@FormatUsd(Model.Total)</strong></div>
                    <hr class="summary-separator" />

                    <label class="summary-gift">
                        <input type="radio" name="orderGift" />
                        <span>
                            <strong>Order includes a gift</strong>
                            <small>Add gift message at checkout</small>
                        </span>
                    </label>

                    <button class="checkout" type="button">Proceed to checkout</button>
                }
                else
                {
                    <div class="cart-note">No items in order summary.</div>
                }
            </section>

            <section class="summary summary--promo" aria-label="Smart membership offer">
                <h3>Unlock $20 OFF</h3>
                <div class="promo-content">
                    <p>Join <strong>Smart+</strong> for free shipping &amp; discounts</p>
                    <img src="~/images/ui/Discount.png" class="promo-icon" alt="" />
                </div>
                <button class="promo-btn" type="button">Try Smart+</button>
            </section>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const section = document.getElementById("saved-favorites-section");
            if (!section) return;

            const tabs = Array.from(section.querySelectorAll("[data-tab-target]"));
            const panels = Array.from(section.querySelectorAll(".saved-panel"));

            const activateTab = (tab) => {
                const targetId = tab.getAttribute("data-tab-target");
                tabs.forEach((item) => {
                    const isActive = item === tab;
                    item.classList.toggle("is-active", isActive);
                    item.setAttribute("aria-selected", isActive ? "true" : "false");
                });

                panels.forEach((panel) => {
                    panel.hidden = panel.id !== targetId;
                });
            };

            tabs.forEach((tab) => {
                tab.addEventListener("click", () => activateTab(tab));
            });

            let isRefreshingFavorites = false;
            document.addEventListener('favorites:changed', () => {
                if (isRefreshingFavorites) {
                    return;
                }

                isRefreshingFavorites = true;
                window.location.reload();
            });
        })();
    </script>
}
