@using System.Globalization
@model Web_Api_Amazon.Models.OrderCompleteViewModel
@{
    ViewData["Title"] = "Order Complete";
}

@functions {
    private static string FormatUsd(decimal amount) => $"${amount.ToString("0.00", CultureInfo.InvariantCulture)}";
}

@section Styles {
    <link rel="stylesheet" href="~/css/checkout.css" asp-append-version="true" />
}

<div class="checkout-page">
    <div class="checkout-steps-wrapper">
        <div class="checkout-steps" aria-label="Checkout progress">
            <div class="step is-completed">
                <span class="dot">
                    <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 5L4.5 8.5L11 1.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <span class="step-text">Shipping</span>
            </div>

            <div class="line is-completed"></div>

            <div class="step is-completed">
                <span class="dot">
                    <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 5L4.5 8.5L11 1.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <span class="step-text">Payment</span>
            </div>

            <div class="line is-completed"></div>

            <div class="step is-completed">
                <span class="dot">
                    <svg width="12" height="10" viewBox="0 0 12 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M1 5L4.5 8.5L11 1.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </span>
                <span class="step-text">Complete</span>
            </div>
        </div>
    </div>

    <div class="complete-container">
        <div class="success-header">
            <div class="success-icon-large">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 13L9 17L19 7" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </div>
            <h2>Your order is completed!</h2>
            <p>Thank you. Your order has been received</p>
        </div>

        <div class="order-info-banner">
            <div class="info-block">
                <span>Order ID</span>
                <strong>#@Model.OrderId@Model.OrderDate.ToString("MMddyy")</strong>
            </div>
            <div class="info-block">
                <span>Estimated delivery</span>
                <strong>@Model.EstimatedDeliveryDate.ToString("MMM dd, yyyy")</strong>
            </div>
            <div class="info-block">
                <span>Payment method</span>
                <strong>@Model.DisplayPaymentMethod</strong>
            </div>
            <div class="info-block">
                <span>Transaction ID</span>
                <strong>@Model.TransactionId</strong>
            </div>
            <div class="info-block">
                <span>Shipping address</span>
                <strong>@Model.ShippingAddress</strong>
            </div>
        </div>

        <div class="order-details-card">
            <div class="order-items-list">
                @foreach (var item in Model.Items)
                {
                    <div class="order-item-row">
                        <div class="item-img-wrapper">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" />
                            }
                        </div>
                        <div class="item-details">
                            <h4>@item.Name</h4>
                            <div class="item-meta">
                                <p>Quantity: &nbsp;@item.Quantity</p>
                            </div>
                        </div>
                        <div class="item-price">
                            <strong>@FormatUsd(item.LineTotal)</strong>
                        </div>
                    </div>
                }
            </div>

            <div class="order-totals-area">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>@FormatUsd(Model.Subtotal)</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span>@FormatUsd(Model.ShippingCost)</span>
                </div>

                <hr class="summary-divider" />

                <div class="summary-row total">
                    <strong>Total</strong>
                    <strong>@FormatUsd(Model.Total)</strong>
                </div>
            </div>
        </div>

        <div class="complete-actions">
            <a asp-controller="Home" asp-action="Index" class="btn-shopping">Continue shopping</a>
            <a href="#" class="btn-track">Track your order</a>
        </div>
    </div>
</div>