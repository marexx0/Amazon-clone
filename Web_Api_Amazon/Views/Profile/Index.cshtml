@using Microsoft.AspNetCore.Identity
@inject UserManager<Web_Api_Amazon.Entities.User> UserManager
@inject SignInManager<Web_Api_Amazon.Entities.User> SignInManager

@{
    Layout = null;
    Web_Api_Amazon.Entities.User currentUser = null;
    if (User.Identity.IsAuthenticated)
        currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personal Account Profile</title>
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    @if (currentUser != null)
    {
        <div class="layout">

            <!-- Sidebar -->
            <aside class="sidebar">
                <div class="sidebar-top">
                    <a class="icon-btn" asp-controller="Home" asp-action="Index">
                        <img src="~/images/iconsPF/chevron-left.png" class="btn-icon" alt="back" />
                    </a>
                    <button class="icon-btn">
                        <img src="~/images/iconsPF/Sidebar.png"
                             asp-append-version="true"
                             alt="back"
                             class="btn-icon" />
                    </button>
                </div>

                    <div class="sidebar-search">
                       
                        <div class="input-icon-wrap">
                            <input type="text"
                                   class="field-input"
                                   placeholder="Search" />

                            <img src="~/images/iconsPF/search.png"
                                 asp-append-version="true"
                                 class="input-icon"
                                 />
                        </div>
                </div>

                <nav class="sidebar-nav">
                   
                    <p class="nav-section">Account</p>
                    <a href="#" class="nav-item active">
                        <img src="~/images/iconsPF/user.png" class="nav-icon" alt="Profile" />
                        Profile
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/Shield.png" class="nav-icon" alt="Security" />
                        Security
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/trending-up.png" class="nav-icon" alt="Activity" />
                        Activity
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/heart.png" class="nav-icon" alt="Favorites" />
                        Favorites
                    </a>

                    <p class="nav-section">Commerce</p>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/package.png" class="nav-icon" alt="Orders" />
                        Orders
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/credit-card.png" class="nav-icon" alt="Payments" />
                        Payments
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/map-pin2.png" class="nav-icon" alt="Addresses" />
                        Addresses
                    </a>

                    <p class="nav-section">System</p>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/bell.png" class="nav-icon" alt="Notifications" />
                        Notifications
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/lock-closed.png" class="nav-icon" alt="Privacy & Data" />
                        Privacy & Data
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/Accessibility.png" class="nav-icon" alt="Accessibility" />
                        Accessibility
                    </a>
                </nav>

                <div class="sidebar-bottom">
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/settings.png" class="nav-icon" alt="Preferences" />
                    Preferences</a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/info.png" class="nav-icon" alt="Support" />
                    Support</a>
                    <a asp-controller="Account" asp-action="Logout" class="nav-item logout">
                        <img src="~/images/iconsPF/Log-out.png" class="nav-icon" alt="Log out" />
                        Log out
                    </a>
                </div>
            </aside>

            <!-- Main content -->
            <main class="content">
                <h1 class="page-title">Profile</h1>
                <p class="page-subtitle">
                    Manage how your account appears and how we communicate with you
                </p>

                <div class="profile-grid">

                    <!-- LEFT COLUMN -->
                    <div class="profile-col">

                        <section class="profile-section">
                            <h2 class="section-heading">Basic information</h2>

                            <div class="field-group">
                                <label class="field-label">Name Surname</label>
                                <input type="text"
                                       class="field-input"
                                       value="@currentUser.FirstName @currentUser.LastName" />
                                <span class="field-hint">
                                    Used to personalize your experience
                                </span>
                            </div>
                        </section>

                        <section class="profile-section">
                            <h2 class="section-heading">Contact information</h2>

                            <div class="contact-row">
                                <div class="field-group">
                                    <label class="field-label">Email</label>
                                    <input type="email"
                                           class="field-input"
                                           value="@currentUser.Email"
                                           readonly />
                                </div>

                                <div class="field-group">
                                    <label class="field-label">Password</label>
                                    <input type="password"
                                           class="field-input"
                                           value="password"
                                           readonly />
                                </div>
                            </div>

                            <p class="security-hint">
                                Change contact information?
                                <a asp-controller="Account" asp-action="Security">
                                    Go to Security page
                                </a>
                            </p>
                        </section>

                    </div>

                    <!-- RIGHT COLUMN -->
                    <div class="profile-col">

                        <section class="profile-section">
                            <h2 class="section-heading">Personal details</h2>

                            <div class="personal-row">

                                <!-- Date of birth -->
                                <div class="field-group">
                                    <label class="field-label">Date of birth</label>

                                    <div class="input-icon-wrap">
                                        <input type="text"
                                               class="field-input"
                                               placeholder="DD/MM/YYYY" />

                                        <img src="~/images/iconsPF/calendar.png"
                                             asp-append-version="true"
                                             class="input-icon"
                                             alt="calendar" />
                                    </div>

                                    <span class="field-hint">
                                        Used only for age-related experiences
                                    </span>
                                </div>

                                <!-- Location -->
                                <div class="field-group">
                                    <label class="field-label">Location</label>

                                    <div class="input-icon-wrap">
                                        <input type="text"
                                               class="field-input"
                                               placeholder="Vienna, Austria" />

                                        <img src="~/images/iconsPF/map-pin.png"
                                             asp-append-version="true"
                                             class="input-icon"
                                             alt="location" />
                                    </div>

                                    <span class="field-hint">
                                        Used for legal purposes
                                    </span>
                                </div>

                            </div>
                        </section>

                        <section class="profile-section">
                            <h2 class="section-heading">Gender identity</h2>

                            <div class="radio-group">
                                <label><input type="radio" name="gender" value="woman" /> Woman</label>
                                <label><input type="radio" name="gender" value="man" /> Man</label>
                                <label><input type="radio" name="gender" value="non-binary" /> Non-binary</label>
                                <label><input type="radio" name="gender" value="prefer-not" /> Prefer not to say</label>
                                <label><input type="radio" name="gender" value="self-describe" checked /> Prefer to self-describe</label>
                            </div>

                            <input type="text"
                                   class="field-input mt-8"
                                   id="genderDescribe"
                                   placeholder="Describe" />

                            <span class="field-hint">
                                This helps us address you respectfully
                            </span>
                        </section>

                    </div>

                </div>
            </main>
        </div>
    }
    else
    {
        <p style="text-align:center;margin-top:60px">
            You must be logged in.
            <a asp-controller="Account" asp-action="Entry">Sign in</a>
        </p>
    }

    <script>
        document.querySelectorAll('input[name="gender"]').forEach(r => {
            r.addEventListener('change', () => {
                document.getElementById('genderDescribe').style.display =
                    r.value === 'self-describe' ? 'block' : 'none';
            });
        });
    </script>

</body>
</html>