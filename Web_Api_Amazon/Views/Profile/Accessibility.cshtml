@{
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
    ViewData["Title"] = "Accessibility";
    ViewData["ActivePage"] = "Accessibility";
}

<h1 class="page-title">Accessibility</h1>
<p class="page-subtitle">
    Customize Allora to match your visual, cognitive, and interaction needs
</p>

<div class="privacy-grid">

    <!-- LEFT COLUMN -->
    <div>

        <section class="privacy-section">
            <h3>Accessibility at a glance</h3>
            <p class="privacy-desc">
                We design Allora to be usable by as many people as possible,
                regardless of ability, device, or context.
            </p>
            <a class="privacy-link">Learn about our accessibility standards</a>
        </section>

        <section class="privacy-section">
            <h3>Text & readability</h3>

            <label class="check-row">
                <input type="checkbox" />
                Text size
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Line spacing
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Font weight
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Dyslexia-friendly mode
            </label>
        </section>

        <section class="privacy-section">
            <h3>Color & contrast</h3>

            <label class="check-row">
                <input type="radio" name="contrast" checked />
                Default
            </label>

            <label class="check-row">
                <input type="radio" name="contrast" />
                High-contrast mode
            </label>

            <label class="check-row">
                <input type="radio" name="contrast" />
                Reduced color saturation
            </label>

            <label class="check-row">
                <input type="radio" name="contrast" />
                Color-blind friendly palettes
            </label>
        </section>

        <section class="privacy-section">
            <h3>Theme</h3>

            <label class="check-row">
                <input type="radio" name="theme" />
                Light
            </label>

            <label class="check-row">
                <input type="radio" name="theme" />
                Dark
            </label>

            <label class="check-row">
                <input type="radio" name="theme" checked />
                System default
            </label>
        </section>

        <section class="privacy-section">
            <h3>Motion & animation</h3>

            <p class="privacy-desc">
                Control motion to reduce discomfort or distraction.
            </p>

            <label class="check-row">
                <input type="checkbox" />
                Reduce motion
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Disable non-essential animations
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Simplified transitions
            </label>
        </section>

    </div>


    <!-- RIGHT COLUMN -->
    <div>

        <section class="privacy-section">
            <h3>Screen reader & assistive technologies</h3>

            <p class="privacy-desc">
                Allora is compatible with modern assistive tools.
            </p>

            <label class="check-row">
                <input type="checkbox" />
                Screen reader labels
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Semantic structures
            </label>

            <label class="check-row">
                <input type="checkbox" />
                ARIA support
            </label>
        </section>

        <section class="privacy-section">
            <h3>Audio & feedback</h3>

            <p class="privacy-desc">
                Control sound-based feedback and alternatives.
            </p>

            <label class="check-row">
                <input type="checkbox" />
                Visual alternatives to sound
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Haptic feedback (where supported)
            </label>
        </section>

        <section class="privacy-section">
            <h3>Cognitive support</h3>

            <p class="privacy-desc">
                Reduce cognitive load and improve clarity.
            </p>

            <label class="check-row">
                <input type="checkbox" />
                Simplified layouts
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Clear language mode
            </label>

            <label class="check-row">
                <input type="checkbox" />
                Reduced information density
            </label>
        </section>

        <section class="privacy-section">
            <h3>Accessibility preferences by account</h3>
            <p class="privacy-desc">
                Accessibility settings can be applied per account or team.
            </p>
            <a class="privacy-link">Manage account-level preferences</a>
        </section>

        <section class="privacy-section">
            <h3>Report an accessibility issue</h3>
            <p class="privacy-desc">
                If something isn’t working for you, we want to fix it.
            </p>
            <a class="privacy-link">Report an issue</a>
        </section>

    </div>

</div>