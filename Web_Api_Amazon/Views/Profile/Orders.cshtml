@model Web_Api_Amazon.Models.ProfileOrdersViewModel

@{
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
    ViewData["Title"] = "Orders";
    ViewData["ActivePage"] = "Orders";

    var inTransitOrders = Model.Orders.Where(o => o.StatusLabel == "In Transit").ToList();
    var completedOrders = Model.Orders.Where(o => o.StatusLabel == "Completed").ToList();
}

<h1 class="page-title">Orders</h1>
<p class="page-subtitle">Track and manage your purchases</p>

<div class="orders-toolbar">
    <div class="orders-filters">
        <button class="orders-filter active" type="button">All orders</button>
        <button class="orders-filter" type="button">Today</button>
        <button class="orders-filter" type="button">Last 7 days</button>
        <button class="orders-filter" type="button">Last 30 days</button>
        <button class="orders-filter" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            Custom range
        </button>
    </div>

    <div class="orders-actions">
        <button class="orders-action-btn" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="6" x2="20" y2="6"></line><line x1="4" y1="12" x2="14" y2="12"></line><line x1="4" y1="18" x2="8" y2="18"></line></svg>
            Sort
        </button>
        <button class="orders-action-btn" type="button">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon></svg>
            Filter
        </button>
    </div>
</div>

@if (!Model.Orders.Any())
{
    <section class="orders-empty-state">
        <img src="~/images/ui/EmptyCart.png" alt="No orders yet" class="orders-empty-image" />
        <h2>No orders yet</h2>
        <p>When you place your first order,<br />it will appear here</p>
        <div class="orders-empty-actions">
            <a href="#" class="orders-learn-btn">Learn about orders</a>
            <a asp-controller="Home" asp-action="Index" class="orders-shop-btn">Start shopping</a>
        </div>
    </section>
}
else
{
    @if (inTransitOrders.Any())
    {
        <section class="orders-section">
            <h2 class="orders-group-title">In Transit</h2>
            <div class="orders-grid">
                @foreach (var order in inTransitOrders)
                {
                    <partial name="_OrderCardPartial" model="order" />
                }
            </div>
        </section>
    }

    @if (completedOrders.Any())
    {
        <section class="orders-section">
            <h2 class="orders-group-title">Completed</h2>
            <div class="orders-grid">
                @foreach (var order in completedOrders)
                {
                    <partial name="_OrderCardPartial" model="order" />
                }
            </div>
        </section>
    }
}