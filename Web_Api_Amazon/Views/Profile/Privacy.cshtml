@{
    Layout = "~/Views/Shared/_ProfileLayout.cshtml";
    ViewData["Title"] = "Privacy & Data";
    ViewData["ActivePage"] = "Privacy";
}

<h1 class="page-title">Privacy & data</h1>
<p class="page-subtitle">Manage your personal information</p>

<div class="privacy-grid">

    <!-- LEFT COLUMN -->
    <div>

        <section class="privacy-section">
            <h3>Your data at a glance</h3>
            <p class="privacy-desc">
                We only collect data that helps us provide, improve, and secure Allora.
            </p>
            <a class="privacy-link">View data summary</a>
        </section>

        <section class="privacy-section">
            <h3>Personal information</h3>

            <label class="check-row">
                <input type="checkbox" checked />
                Name and profile details
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Contact information
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Country, region, and preferences
            </label>
        </section>

        <section class="privacy-section">
            <h3>Account data</h3>

            <label class="check-row">
                <input type="checkbox" checked />
                Account activity
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Orders and interactions
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Saved items and preferences
            </label>
        </section>

        <section class="privacy-section">
            <h3>Communication preferences</h3>

            <label class="check-row">
                <input type="checkbox" checked />
                Product updates
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Policy and legal notifications
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Security alerts
            </label>
        </section>

        <section class="privacy-section">
            <h3>Need help?</h3>
            <p class="privacy-desc">
                If you have questions about your data or privacy rights, we're here to help.
            </p>
            <a class="privacy-link">Contact privacy support</a>
        </section>

    </div>


    <!-- RIGHT COLUMN -->
    <div>

        <section class="privacy-section">
            <h3>Cookies & tracking</h3>

            <label class="check-row">
                <input type="checkbox" checked />
                Essential cookies
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Analytics and performance cookies
            </label>

            <label class="check-row">
                <input type="checkbox" checked />
                Personalization cookies
            </label>
        </section>

        <section class="privacy-section">
            <h3>Data sharing & third parties</h3>
            <p class="privacy-desc">
                We never sell your data. Some data may be shared with trusted partners to provide
                essential services such as payments or deliveries.
            </p>
            <a class="privacy-link">View third-party partners</a>
        </section>

        <section class="privacy-section">
            <h3>Download your data</h3>
            <p class="privacy-desc">
                You can request a copy of your personal data at any time.
            </p>
            <a class="privacy-link">Request data export</a>
        </section>

        <section class="privacy-section">
            <h3>Data protection and compliance updates</h3>
            <p class="privacy-desc">
                Allora follows international data protection standards, including GDPR and
                applicable local regulations.
            </p>
            <a class="privacy-link">Learn about our compliance</a>
        </section>

        <section class="privacy-section">
            <h3>Delete your data</h3>
            <p class="privacy-desc">
                You're in control. You can request permanent deletion of your data.
            </p>
            <a class="privacy-danger">Request data deletion</a>
            <p class="privacy-warning">
                This action is irreversible and may affect access to services.
            </p>
        </section>

    </div>

</div>