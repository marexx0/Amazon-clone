@using Microsoft.AspNetCore.Identity
@using Web_Api_Amazon.Entities
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager

@{
    Web_Api_Amazon.Entities.User currentUser = null;
    if (User.Identity.IsAuthenticated)
        currentUser = await UserManager.GetUserAsync(User);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    @if (currentUser != null)
    {
        <div class="layout">

            <!-- Sidebar -->
            <aside class="sidebar" id="profileSidebar">
                <div class="sidebar-top">
                    <a class="icon-btn" href="@Url.Action("Index", "Home")" aria-label="Go to main page">
                        <img src="~/images/iconsPF/chevron-left.png"
                             asp-append-version="true"
                             alt="Go to main page"
                             class="btn-icon" />
                    </a>
                    <button class="icon-btn sidebar-toggle" type="button" id="sidebarToggle" aria-label="Toggle profile menu" aria-expanded="false" aria-controls="profileSidebar">
                        <img src="~/images/iconsPF/Sidebar.png"
                             asp-append-version="true"
                             alt="Toggle sidebar"
                             class="btn-icon" />
                    </button>
                </div>

                <div class="sidebar-search">

                    <div class="input-icon-wrap">
                        <input type="text"
                               class="field-input"
                               placeholder="Search" />

                        <img src="~/images/iconsPF/search.png"
                             asp-append-version="true"
                             class="input-icon" />
                    </div>
                </div>

                <nav class="sidebar-nav">

                    <p class="nav-section">Account</p>

                    <a asp-controller="Profile" asp-action="Index"
                       class="nav-item @(ViewData["ActivePage"]?.ToString() == "Profile" ? "active" : "")">
                        <img src="~/images/iconsPF/user.png" class="nav-icon" alt="Profile" />
                        Profile
                    </a>

                    <a asp-controller="Profile" asp-action="Security"
                       class="nav-item @(ViewData["ActivePage"]?.ToString() == "Security" ? "active" : "")">
                        <img src="~/images/iconsPF/Shield.png" class="nav-icon" alt="Security" />
                        Security
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/trending-up.png" class="nav-icon" alt="Activity" />
                        Activity
                    </a>
                    <a asp-controller="Favorites" asp-action="Index"
                       class="nav-item @(ViewData["ActivePage"]?.ToString() == "Favorites" ? "active" : "")">
                        <img src="~/images/iconsPF/heart.png" class="nav-icon" alt="Favorites" />
                        Favorites
                    </a>

                    <p class="nav-section">Commerce</p>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/package.png" class="nav-icon" alt="Orders" />
                        Orders
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/credit-card.png" class="nav-icon" alt="Payments" />
                        Payments
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/map-pin2.png" class="nav-icon" alt="Addresses" />
                        Addresses
                    </a>

                    <p class="nav-section">System</p>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/bell.png" class="nav-icon" alt="Notifications" />
                        Notifications
                    </a>
                   
                    <a asp-controller="Profile" asp-action="Privacy"
                       class="nav-item @(ViewData["ActivePage"]?.ToString() == "Privacy" ? "active" : "")">
                        <img src="~/images/iconsPF/lock-closed.png" class="nav-icon" alt="Security" />
                        Privacy & Data
                    </a>
                    <a asp-controller="Profile" asp-action="Accessibility"
                       class="nav-item @(ViewData["ActivePage"]?.ToString() == "Accessibility" ? "active" : "")">
                        <img src="~/images/iconsPF/Accessibility.png" class="nav-icon" />
                        Accessibility
                    </a>
                </nav>

                <div class="sidebar-bottom">
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/settings.png" class="nav-icon" alt="Preferences" />
                        Preferences
                    </a>
                    <a href="#" class="nav-item">
                        <img src="~/images/iconsPF/info.png" class="nav-icon" alt="Support" />
                        Support
                    </a>
                    <a asp-controller="Account" asp-action="Logout" class="nav-item logout">
                        <img src="~/images/iconsPF/Log-out.png" class="nav-icon" alt="Log out" />
                        Log out
                    </a>
                </div>
            </aside>

            <!-- Main content -->
            <main class="content">
                @RenderBody()
            </main>
            <button class="sidebar-overlay" type="button" id="sidebarOverlay" aria-label="Close profile menu"></button>

        </div>
    }
    else
    {
        <p style="text-align:center;margin-top:60px">
            You must be logged in.
            <a asp-controller="Account" asp-action="Entry">Sign in</a>
        </p>
    }
    <script>
        (function () {
            const sidebar = document.getElementById('profileSidebar');
            const toggleButton = document.getElementById('sidebarToggle');
            const overlay = document.getElementById('sidebarOverlay');

            if (!sidebar || !toggleButton || !overlay) {
                return;
            }

            const closeSidebar = () => {
                sidebar.classList.remove('sidebar-open');
                overlay.classList.remove('is-visible');
                toggleButton.setAttribute('aria-expanded', 'false');
            };

            const openSidebar = () => {
                sidebar.classList.add('sidebar-open');
                overlay.classList.add('is-visible');
                toggleButton.setAttribute('aria-expanded', 'true');
            };

            toggleButton.addEventListener('click', () => {
                const isOpen = sidebar.classList.contains('sidebar-open');
                if (isOpen) {
                    closeSidebar();
                    return;
                }

                openSidebar();
            });

            overlay.addEventListener('click', closeSidebar);

            window.addEventListener('resize', () => {
                if (window.innerWidth > 767) {
                    closeSidebar();
                }
            });
        })();
    </script>

    @RenderSection("Scripts", required: false)

</body>
</html>