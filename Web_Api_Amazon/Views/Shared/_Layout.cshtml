<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web_Api_Amazon</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/Web_Api_Amazon.styles.css" asp-append-version="true" />
</head>
<body class="site-shell">
    <header class="site-header">
        <div class="container-fluid site-header__inner">
            <a class="site-header__logo" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Allora home">
                <img src="~/images/ui/Logo.png" alt="Allora" />
            </a>

            <button type="button" class="site-header__location" aria-label="Select location">
                <img src="~/images/ui/map-pin.png" alt="" aria-hidden="true" />
                <span class="site-header__location-text">Vienna, Austria</span>
                <span class="site-header__chevron"><img src="~/images/ui/chevron-down.png" alt="" aria-hidden="true" /></span>
            </button>

            <form class="site-header__search" role="search">
                <label class="visually-hidden" for="site-search">Search</label>
                <select aria-label="Category">
                    <option selected>Category</option>
                </select>
                <input id="site-search" type="search" placeholder="Search" aria-label="Search" />
                <button type="submit" aria-label="Submit search">
                    <img src="~/images/ui/Search.png" alt="" aria-hidden="true" />
                </button>
            </form>

            <div class="site-header__actions">
                <button type="button" class="site-header__action site-header__lang" aria-label="Language">
                    <span aria-hidden="true"><img src="~/images/ui/Globe.png" alt="" aria-hidden="true" /></span>
                    <span class="site-header__language-text">English</span>
                    <span class="site-header__chevron"><img src="~/images/ui/chevron-down.png" alt="" aria-hidden="true" /></span>
                </button>
                <button type="button" class="site-header__action" aria-label="Notifications">
                    <img src="~/images/ui/Notifications.png" alt="" aria-hidden="true" />
                </button>
                <button type="button" class="site-header__action" aria-label="Favorites">
                    <img src="~/images/ui/Favorites.png" alt="" aria-hidden="true" />
                </button>
                <a class="site-header__action" asp-controller="Cart" asp-action="Index" aria-label="Cart">
                    <img src="~/images/ui/Cart.png" alt="" aria-hidden="true" />
                </a>
                <a class="site-header__action" asp-controller="Account" asp-action="Login" aria-label="Profile">
                    <img src="~/images/ui/Profile.png" alt="" aria-hidden="true" />
                </a>
            </div>
        </div>
    </header>

    <div class="site-content container-fluid px-3 px-md-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">About Allora</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">About Allora</a></li>
                        <li><a href="#">Our Approach</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press &amp; Updates</a></li>
                        <li><a href="#">Accessibility Commitment</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">For Business</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Sell with Allora</a></li>
                        <li><a href="#">Business Accounts</a></li>
                        <li><a href="#">Product Management</a></li>
                        <li><a href="#">Analytics &amp; Insights</a></li>
                        <li><a href="#">Advertising Tools</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Payments &amp; Orders</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Payment Methods</a></li>
                        <li><a href="#">Invoices &amp; Billing</a></li>
                        <li><a href="#">Order Tracking</a></li>
                        <li><a href="#">Returns &amp; Refunds</a></li>
                        <li><a href="#">Delivery Information</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Help &amp; Support</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Account &amp; Security</a></li>
                        <li><a href="#">Privacy &amp; Data</a></li>
                        <li><a href="#">Contact Support</a></li>
                        <li><a href="#">Report an Issue</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Legal</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Cookie Preferences</a></li>
                        <li><a href="#">Accessibility Statement</a></li>
                    </ul>
                </div>
            </div>
                <div class="site-footer__copy">&copy; 2026 Allora. All rights reserved</div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
