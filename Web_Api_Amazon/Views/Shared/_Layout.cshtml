@using Microsoft.AspNetCore.Identity
@using Web_Api_Amazon.Entities
@using Web_Api_Amazon.Models
@using System.Collections.Generic
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Allora</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/Web_Api_Amazon.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Overlay � ��� ���� ���������� ������� ���� -->
    <div id="profileOverlay"></div>

    <header class="main-header">
        <div class="header-inner">
			<div class="header-left">
                    <a asp-controller="Home" asp-action="Index" class="logo" aria-label="Logo">
					    <img src="~/imagesmain/Logo.png" alt="Allora logo" class="brand-logo">
                    </a>

                <button type="button" class="header-location" aria-label="Select location">
                    <img src="~/imagesmain/map-pin.png" alt="location" class="icon-36">
                    <span>Vienna, Austria</span>
                    <img src="~/imagesmain/chevron-down.png" alt="open" class="icon-36">
                </button>
            </div>

            <div class="header-center">

                <div class="cat-wrapper">
                    <button class="cat-btn" id="catBtn">
                        Category <span class="cat-arrow">&#9660;</span>
                    </button>

                    <div class="cat-dropdown" id="catDropdown">
                        @{
                            var activeCat = Context.Request.Query["categoryId"].ToString();
                        }
                        <a href="/?categoryId=6" class="cat-item">
                            <img src="~/imagesmain/clothe.png" alt="">
                            Clothing
                        </a>

                        <a href="/?categoryId=7" data-category-id="7" class="cat-item">
                            <img src="~/imagesmain/shoes.png" alt="">
                            Shoes
                        </a>

                        <a href="/?categoryId=8" class="cat-item">
                            <img src="~/imagesmain/computer.png" alt="">
                            Computers / Laptops / Tablets
                        </a>

                        <a href="/?categoryId=9" class="cat-item">
                            <img src="~/imagesmain/phone.png" alt="">
                            Mobile Phones
                        </a>

                        <a href="/?categoryId=10" class="cat-item">
                            <img src="~/imagesmain/Audio.png" alt="">
                            Headphone
                        </a>

                        <a href="/?categoryId=11" class="cat-item">
                            <img src="~/imagesmain/photo.png" alt="">
                            Cameras / Photo Equipment
                        </a>

                        <a href="/?categoryId=12" class="cat-item">
                            <img src="~/imagesmain/Game.png" alt="">
                            Gaming
                        </a>

                        <a href="/?categoryId=13" class="cat-item">
                            <img src="~/imagesmain/Home.png" alt="">
                            Home Decor
                        </a>

                        <a href="/?categoryId=14" class="cat-item">
                            <img src="~/imagesmain/Furniture.png" alt="">
                            Furniture
                        </a>

                        <a href="/?categoryId=15" class="cat-item">
                            <img src="~/imagesmain/Light.png" alt="">
                            Lighting
                        </a>

                        <a href="/?categoryId=16" class="cat-item">
                            <img src="~/imagesmain/Yard.png" alt="">
                            Yard and Garden
                        </a>

                        <a href="/?categoryId=17" class="cat-item">
                            <img src="~/imagesmain/Plumbing.png" alt="">
                            Tools / Hardware / Plumbing
                        </a>

                        <a href="/?categoryId=19" class="cat-item">
                            <img src="~/imagesmain/sport.png" alt="">
                            Sports / Outdoor / Fitness
                        </a>

                        <a href="/?categoryId=21" class="cat-item">
                            <img src="~/imagesmain/toys.png" alt="">
                            Toys Kids
                        </a>

                        <a href="/?categoryId=22" class="cat-item">
                            <img src="~/imagesmain/book.png" alt="">
                            Books / Media
                        </a>

                        <a href="/?categoryId=23" class="cat-item">
                            <img src="~/imagesmain/Health.png" alt="">
                            Health
                        </a>

                    </div>
                </div>

                <!--  SEARCH -->
                <form asp-controller="Home"
                      asp-action="Index"
                      method="get"
                      class="search-form">

                    <input type="text"
                           name="searchString"
                           value="@Context.Request.Query["searchString"]"
                           placeholder="Search products..."
                           class="search-input" />

                    <button type="submit" class="search-btn">
                        <img src="~/imagesmain/search.png" alt="search" class="icon-36">
                    </button>
                </form>

            </div>

            <div class="header-right">
                <button type="button" class="header-lang" aria-label="Choose language">
                    <img src="~/imagesmain/globe.png" alt="language" class="icon-36">
                    <span>English</span>
                    <img src="~/imagesmain/chevron-down.png" alt="open" class="icon-36">
                </button>

                <button type="button" class="header-icon-btn" aria-label="Notifications">
                    <img src="~/imagesmain/bell.png" alt="Notifications" class="icon-36">
                </button>

                <button type="button" class="header-icon-btn" aria-label="Favorites">
                    <img src="~/imagesmain/heart.png" alt="Favorites" class="icon-36">
                </button>

                <a asp-controller="Cart" asp-action="Index" class="header-icon-btn" aria-label="Cart">
                    <img src="~/imagesmain/shopping-cart.png" alt="Cart" class="icon-36">
                </a>

                <!-- PROFILE � ���������� -->
                <div class="profile-wrapper">
                    <button class="profile-btn" id="profileBtn" title="Account">
                        <img src="~/imagesmain/Account Photo.png" alt="profile" style="width:44px; height:44px;">
                    </button>

                    <div class="profile-dropdown" id="profileDropdown">
                        @{

                            User? currentUser = null;

                            if (User.Identity.IsAuthenticated)
                            {
                                currentUser = await UserManager.GetUserAsync(User);
                            }
                        }

                        @if (currentUser != null)
                        {
                            <div class="dd-user">
                                <div class="dd-user-name">
                                    Hello, <strong>@currentUser.FirstName</strong>
                                </div>

                                <div class="dd-actions-row">

                                    @if (await UserManager.IsInRoleAsync(currentUser, "Admin"))
                                    {
                                        <a asp-controller="AdminPanel"
                                           asp-action="Index"
                                           class="dd-btn secondary">
                                            Admin Panel
                                        </a>
                                    }

                                    <a asp-controller="Profile"
                                       asp-action="Index"
                                       class="dd-btn primary">
                                        Profile
                                    </a>

                                </div>

                                <div class="dd-signout">
                                    <a asp-controller="Account"
                                       asp-action="Logout"
                                       class="logout-btn">
                                        Log out
                                    </a>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="dd-signin">
                                <a asp-controller="Account"
                                   asp-action="Entry"
                                   class="n-signin">
                                    Sign in
                                </a>

                                <p class="dd-signin-sub">
                                    New customer?
                                    <a asp-controller="Account"
                                       asp-action="Register">
                                        Start here
                                    </a>
                                </p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-links">
                <div class="footer-col">
                    <h5 class="site-footer__title">About Allora</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">About Allora</a></li>
                        <li><a href="#">Our Approach</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press &amp; Updates</a></li>
                        <li><a href="#">Accessibility Commitment</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5 class="site-footer__title">For Business</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Sell with Allora</a></li>
                        <li><a href="#">Business Accounts</a></li>
                        <li><a href="#">Product Management</a></li>
                        <li><a href="#">Analytics & Insights</a></li>
                        <li><a href="#">Advertising Tools</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5 class="site-footer__title">Payments & Orders</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Payments Methods</a></li>
                        <li><a href="#">Invoces & Billing</a></li>
                        <li><a href="#">Order Tracking</a></li>
                        <li><a href="#">Return & Refunds</a></li>
                        <li><a href="#">Delivery Information</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5 class="site-footer__title">Help & Support</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Account & Security</a></li>
                        <li><a href="#">Privacy & Data</a></li>
                        <li><a href="#">Contact Support</a></li>
                        <li><a href="#">Report an Issue</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h5 class="site-footer__title">Legal</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#" style="color: #FCFCFC; font-family: 'DM Sans', sans-serif;">Privacy Policy</a></li>
                        <li><a href="#">Cookie Preferences</a></li>
                        <li><a href="#">Accessibility Statement</a></li>
                    </ul>
                </div>
            </div>

            <div class="site-footer__bottom">
                <img src="~/imagesmain/Logo.png" alt="Allora" class="footer-logo">

                <div class="footer-bottom-item">
                    <img src="~/imagesmain/map-pin.png" alt="" class="icon-36">
                    <span>Vienna, Austria</span>
                    <img src="~/imagesmain/chevron-down.png" alt="" class="icon-36">
                </div>

                <div class="footer-bottom-item">
                    <img src="~/imagesmain/globe.png" alt="" class="icon-36">
                    <span>English</span>
                    <img src="~/imagesmain/chevron-down.png" alt="" class="icon-36">
                </div>

                <div class="footer-bottom-item">
                    <img src="~/imagesmain/Euro.png" alt="" class="icon-36">
                    <span>Euro</span>
                    <img src="~/imagesmain/chevron-down.png" alt="" class="icon-36">
                </div>

                <span>2026 Allora. All rights reserved</span>
            </div>
        </div>
    </footer>

    <nav class="mobile-bottom-nav" aria-label="Mobile navigation">
        <a asp-controller="Home" asp-action="Index" class="mobile-bottom-nav__item" aria-label="Menu">
            <span class="mobile-bottom-nav__icon mobile-bottom-nav__icon-menu" aria-hidden="true"></span>
        </a>

        <a asp-controller="Favorites" asp-action="Index" class="mobile-bottom-nav__item" aria-label="Favorites">
            <img src="~/imagesmain/heart.png" alt="" class="mobile-bottom-nav__img-icon" />
        </a>

        <a asp-controller="Home" asp-action="Index" class="mobile-bottom-nav__item mobile-bottom-nav__item--active" aria-label="Search">
            <img src="~/imagesmain/search.png" alt="" class="mobile-bottom-nav__img-icon" />
        </a>

        <a asp-controller="Cart" asp-action="Index" class="mobile-bottom-nav__item" aria-label="Cart">
            <img src="~/imagesmain/shopping-cart.png" alt="" class="mobile-bottom-nav__img-icon" />
        </a>

        @if (SignInManager.IsSignedIn(User))
        {
            <a asp-controller="Profile" asp-action="Index" class="mobile-bottom-nav__item" aria-label="Profile">
                <img src="~/imagesmain/Account Photo.png" alt="" class="mobile-bottom-nav__img-icon" />
            </a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Entry" class="mobile-bottom-nav__item" aria-label="Sign in">
                <img src="~/imagesmain/Account Photo.png" alt="" class="mobile-bottom-nav__img-icon" />
            </a>
        }
    </nav>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>