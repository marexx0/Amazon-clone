<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Allora</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/Web_Api_Amazon.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Overlay — ęëłę ďîçŕ äđîďäŕóíîě çŕęđčâŕş éîăî -->
    <div id="profileOverlay"></div>

    <header class="main-header">
        <div class="header-left">
            <div class="logo">
                <img src="imagesmain/LogoGreen.png" alt="logo icon" class="icon-36">
            </div>
            <img src="imagesmain/map-pin.png" alt="location icon" class="icon-36">
            <div class="location">
                Vienna, Austria
                <img src="imagesmain/chevron-down.png" alt="down icon" class="icon-36">
            </div>
        </div>

        <div class="header-center">
            <select class="category-select">
                <option>Category</option>
            </select>
            <input type="text" placeholder="Search">
            <button class="search-btn">
                <img src="imagesmain/search.png" alt="search" class="icon-36">
            </button>
        </div>

        <div class="header-right">
            <div class="globe">
                <img src="imagesmain/globe.png" alt="logo icon" class="icon-36">
            </div>
            <span>English<img src="imagesmain/chevron-down.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/Button.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/ButtonFAV.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/ButtonCart.png" alt="logo icon" class="icon-36"></span>

            <!-- PROFILE ç äđîďäŕóíîě — çŕěłńňü ńňŕđîăî <span><img ButtonProfile...> -->
            <div class="profile-wrapper">
                <button class="profile-btn" id="profileBtn" title="Account">
                    <img src="imagesmain/ButtonProfile.png" alt="profile" class="icon-36">
                    
                </button>

                <div class="profile-dropdown" id="profileDropdown">

                    <!-- Sign in -->
                    @if (User.Identity.IsAuthenticated)
                    {
                        <div class="dd-signin">
                            <strong>@User.Identity.Name</strong>
                        </div>

                        <div class="dd-signout">
                            <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                                Sign out
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="dd-signin">
                            <a asp-controller="Account" asp-action="Login" class="n-signin">
                                Sign in
                            </a>
                            <p class="dd-signin-sub">
                                New customer?
                                <a asp-controller="Account" asp-action="Register">Start here</a>
                            </p>
                        </div>
                    }

                  
                    <!-- Äâł ęîëîíęč -->
                    <div class="dd-cols">
                        <div class="dd-col">
                            <div class="dd-col-title">Your Lists</div>
                            <ul class="dd-link-list">
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <line x1="12" y1="5" x2="12" y2="19" />
                                            <line x1="5" y1="12" x2="19" y2="12" />
                                        </svg>
                                        Create a List
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z" />
                                        </svg>
                                        Find a List
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                                        </svg>
                                        Wish List
                                    </a>
                                </li>
                            </ul>
                        </div>

                        <div class="dd-col">
                            <div class="dd-col-title">Your Account</div>
                            <ul class="dd-link-list">
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <circle cx="12" cy="7" r="4" />
                                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                        </svg>
                                        Account
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                                            <line x1="3" y1="6" x2="21" y2="6" />
                                        </svg>
                                        Orders
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                            <circle cx="12" cy="12" r="3" />
                                        </svg>
                                        Browsing History
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <circle cx="12" cy="12" r="3" />
                                            <path d="M19.07 4.93A10 10 0 1 1 4.93 19.07" />
                                        </svg>
                                        Recommendations
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <rect x="1" y="4" width="22" height="16" rx="2" />
                                            <line x1="1" y1="10" x2="23" y2="10" />
                                        </svg>
                                        Payments
                                    </a>
                                </li>
                                <li>
                                    <a href="#">
                                        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                            <path d="M18 8h1a4 4 0 0 1 0 8h-1" />
                                            <path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z" />
                                        </svg>
                                        Preferences
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Sign out -->
                    <div class="dd-signout">
                        <a >
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                <polyline points="16 17 21 12 16 7" />
                                <line x1="21" y1="12" x2="9" y2="12" />
                            </svg>
                            Sign out
                        </a>
                    </div>

                </div><!-- /profile-dropdown -->
            </div><!-- /profile-wrapper -->

        </div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">About Allora</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">About Allora</a></li>
                        <li><a href="#">Our Approach</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press &amp; Updates</a></li>
                        <li><a href="#">Accessibility Commitment</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">For Business</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Sell with Allora</a></li>
                        <li><a href="#">Business Accounts</a></li>
                        <li><a href="#">Product Management</a></li>
                        <li><a href="#">Analytics &amp; Insights</a></li>
                        <li><a href="#">Advertising Tools</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Payments &amp; Orders</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Payment Methods</a></li>
                        <li><a href="#">Invoices &amp; Billing</a></li>
                        <li><a href="#">Order Tracking</a></li>
                        <li><a href="#">Returns &amp; Refunds</a></li>
                        <li><a href="#">Delivery Information</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Help &amp; Support</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Account &amp; Security</a></li>
                        <li><a href="#">Privacy &amp; Data</a></li>
                        <li><a href="#">Contact Support</a></li>
                        <li><a href="#">Report an Issue</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Legal</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Cookie Preferences</a></li>
                        <li><a href="#">Accessibility Statement</a></li>
                    </ul>
                </div>
            </div>
            <div class="site-footer__bottom">
                <div class="site-footer__brand">allora</div>
                <div class="site-footer__meta">
                    <span class="footer-chip">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2.25c-3.86 0-7 3.05-7 6.8 0 4.94 5.84 11.73 6.09 12.01a1 1 0 0 0 1.55 0c.25-.28 6.36-7.07 6.36-12.01 0-3.75-3.14-6.8-7-6.8zm0 9.4a2.6 2.6 0 1 1 0-5.2 2.6 2.6 0 0 1 0 5.2z" />
                        </svg>
                        Vienna, Austria
                    </span>
                    <span class="footer-chip">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2.5c-5.24 0-9.5 4.26-9.5 9.5s4.26 9.5 9.5 9.5 9.5-4.26 9.5-9.5-4.26-9.5-9.5-9.5zm6.7 9.5a6.7 6.7 0 0 1-.95 3.43h-2.5a15.1 15.1 0 0 0 0-6.86h2.5A6.7 6.7 0 0 1 18.7 12zm-6.7 6.7c-.64-.93-1.37-2.45-1.78-4.27h3.56c-.41 1.82-1.14 3.34-1.78 4.27zM9.43 12c0-.95.1-1.86.29-2.71h4.56c.19.85.29 1.76.29 2.71s-.1 1.86-.29 2.71H9.72A12.7 12.7 0 0 1 9.43 12zm2.57-7.2c.64.93 1.37 2.45 1.78 4.27H10.2c.41-1.82 1.14-3.34 1.78-4.27zM5.3 12c0-1.2.32-2.34.95-3.43h2.5a15.1 15.1 0 0 0 0 6.86h-2.5A6.7 6.7 0 0 1 5.3 12z" />
                        </svg>
                        English
                    </span>
                    <span class="footer-chip">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12.75 3.25a.75.75 0 0 0-1.5 0v1.7c-2.73.3-4.75 2-4.75 4.32 0 2.2 1.8 3.58 4.6 4.26 2.5.6 3.2 1.35 3.2 2.43 0 1.14-1.07 2.05-2.8 2.05-1.72 0-2.9-.72-3.28-2.02a.75.75 0 1 0-1.44.42c.47 1.62 2.03 2.73 4.47 2.97v1.62a.75.75 0 0 0 1.5 0v-1.6c2.68-.28 4.5-2 4.5-4.24 0-2.25-1.7-3.64-4.5-4.32-2.37-.58-3.3-1.26-3.3-2.4 0-1.2 1.13-2.05 2.75-2.05 1.28 0 2.25.49 2.7 1.4a.75.75 0 1 0 1.34-.66c-.54-1.08-1.65-1.82-3.33-2.06z" />
                        </svg>
                        Euro
                    </span>
                </div>
                <div class="site-footer__copy">&copy; 2026 Allora. All rights reserved</div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
