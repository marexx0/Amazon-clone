@using Microsoft.AspNetCore.Identity
@using Web_Api_Amazon.Entities
@using Web_Api_Amazon.Models
@using Web_Api_Amazon.Entities
@using System.Collections.Generic
@inject UserManager<User> UserManager
@inject SignInManager<User> SignInManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] Allora</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <link rel="stylesheet" href="~/Web_Api_Amazon.styles.css" asp-append-version="true" />
</head>
<body>

    <!-- Overlay — ęëłę ďîçŕ äđîďäŕóíîě çŕęđčâŕş éîăî -->
    <div id="profileOverlay"></div>

    <header class="main-header">
        <div class="header-left">
            <div class="logo">
                <img src="imagesmain/LogoGreen.png" alt="logo icon" class="icon-36">
            </div>
            <img src="imagesmain/map-pin.png" alt="location icon" class="icon-36">
            <div class="location">
                Vienna, Austria
                <img src="imagesmain/chevron-down.png" alt="down icon" class="icon-36">
            </div>
        </div>
        <div class="header-center">

            <div class="cat-wrapper">
                <button class="cat-btn" id="catBtn">
                    Category <span class="cat-arrow">&#9660;</span>
                </button>

                <div class="cat-dropdown" id="catDropdown">

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/tshirt.png" alt="">
                        Clothing
                    </a>

                    <a href="#" data-category-id="7" class="cat-item">
                        <img src="imagesmain/icons/shoes.png" alt="">
                        Shoes
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/laptop.png" alt="">
                        Computers / Laptops / Tablets
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/phone.png" alt="">
                        Mobile Phones
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/headphones.png" alt="">
                        Headphone
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/camera.png" alt="">
                        Cameras / Photo Equipment
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/gaming.png" alt="">
                        Gaming
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/home.png" alt="">
                        Home Decor
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/furniture.png" alt="">
                        Furniture
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/light.png" alt="">
                        Lighting
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/garden.png" alt="">
                        Yard and Garden
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/tools.png" alt="">
                        Tools / Hardware / Plumbing
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/building.png" alt="">
                        Building Materials
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/sport.png" alt="">
                        Sports / Outdoor / Fitness
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/car.png" alt="">
                        Auto Parts / Accessories
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/toys.png" alt="">
                        Toys Kids
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/books.png" alt="">
                        Books / Media
                    </a>

                    <a href="#" class="cat-item">
                        <img src="imagesmain/icons/health.png" alt="">
                        Health
                    </a>

                </div>
            </div>

            <!--  SEARCH -->
            <form asp-controller="Home"
                  asp-action="Index"
                  method="get"
                  class="search-form">

                <input type="text"
                       name="searchString"
                       value="@Context.Request.Query["searchString"]"
                       placeholder="Search products..."
                       class="search-input" />

                <button type="submit" class="search-btn">
                    <img src="imagesmain/search.png" alt="search" class="icon-36">
                </button>
            </form>

        </div>

        <div class="header-right">
            <div class="globe">
                <img src="imagesmain/globe.png" alt="logo icon" class="icon-36">
            </div>
            <span>English<img src="imagesmain/chevron-down.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/Button.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/ButtonFAV.png" alt="logo icon" class="icon-36"></span>
            <span><img src="imagesmain/ButtonCart.png" alt="logo icon" class="icon-36"></span>

            <!-- PROFILE ç äđîďäŕóíîě -->
            <div class="profile-wrapper">
                <button class="profile-btn" id="profileBtn" title="Account">
                    <img src="imagesmain/ButtonProfile.png" alt="profile" class="icon-36">
                </button>

                <div class="profile-dropdown" id="profileDropdown">
                    @{
                        // Çěłííŕ îăîëîřĺíŕ çîâíł — ňĺďĺđ äîńňóďíŕ ó âńüîěó áëîöł
                        User? currentUser = null;

                        if (User.Identity.IsAuthenticated)
                        {
                            currentUser = await UserManager.GetUserAsync(User);
                        }
                    }

                    @if (currentUser != null)
                    {
                        <div class="dd-signin">
                            <strong>@currentUser.FirstName</strong>
                        </div>

                        @if (await UserManager.IsInRoleAsync(currentUser, "Admin"))
                        {
                            <div class="dd-admin">
                                <a asp-controller="AdminPanel" asp-action="Index" class="admin-btn">
                                    Admin Panel
                                </a>
                            </div>
                        }

                        <div class="dd-signout">
                            <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                                Sign out
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="dd-signin">
                            <a asp-controller="Account" asp-action="Entry" class="n-signin">
                                Sign in
                            </a>
                            <p class="dd-signin-sub">
                                New customer?
                                <a asp-controller="Account" asp-action="Register">Start here</a>
                            </p>
                        </div>
                    }

                        @* Ëłíę íŕ ŕäěłíęó ëčřĺ äë˙ Admin *@
                        @* @if (await UserManager.IsInRoleAsync(currentUser, "Admin"))
                        {
                            <div class="dd-admin">
                                <a asp-controller="AdminPanel" asp-action="Index" class="admin-btn">
                                    Admin Panel
                                </a>
                            </div>
                        }

                        <div class="dd-signout">
                            <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                                Sign out
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="dd-signin">
                            <a asp-controller="Account" asp-action="Entry" class="n-signin">
                                Sign in
                            </a>
                            <p class="dd-signin-sub">
                                New customer?
                                <a asp-controller="Account" asp-action="Register">Start here</a>
                            </p>
                        </div>
                    }
                </div>
            </div> *@

        </div>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container">
            <div class="row gy-4">
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">About Allora</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">About Allora</a></li>
                        <li><a href="#">Our Approach</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press &amp; Updates</a></li>
                        <li><a href="#">Accessibility Commitment</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">For Business</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Sell with Allora</a></li>
                        <li><a href="#">Business Accounts</a></li>
                        <li><a href="#">Product Management</a></li>
                        <li><a href="#">Analytics &amp; Insights</a></li>
                        <li><a href="#">Advertising Tools</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Payments &amp; Orders</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Payment Methods</a></li>
                        <li><a href="#">Invoices &amp; Billing</a></li>
                        <li><a href="#">Order Tracking</a></li>
                        <li><a href="#">Returns &amp; Refunds</a></li>
                        <li><a href="#">Delivery Information</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Help &amp; Support</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Account &amp; Security</a></li>
                        <li><a href="#">Privacy &amp; Data</a></li>
                        <li><a href="#">Contact Support</a></li>
                        <li><a href="#">Report an Issue</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5 class="site-footer__title">Legal</h5>
                    <ul class="site-footer__list">
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Cookie Preferences</a></li>
                        <li><a href="#">Accessibility Statement</a></li>
                    </ul>
                </div>


                <div class="site-footer__bottom">
                    <div class="site-footer__brand">
                        <img src="imagesmain/LogoGreen.png" alt="">
                    </div>
                    <img src="imagesmain/map-pin.png" alt="location icon" class="site-footer__meta">
                    <div class="footer-location">
                        Vienna, Austria
                        <img src="imagesmain/chevron-down.png" alt="down icon" class="icon-36">
                    </div>
                   

                    <div class="footer-chip">
                        <img src="imagesmain/globe.png" alt="logo icon" >
                    </div>
                    <span>English<img src="imagesmain/chevron-down.png" alt="logo icon" ></span>
                    <img src="imagesmain/Euro.png" alt="logo icon">
                    <span>Euro<img src="imagesmain/chevron-down.png" alt="logo icon"></span>
                    <span class="footer-chip"> © 2026 Allora. All rights reserved</span>
                    </div>
             
                </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
