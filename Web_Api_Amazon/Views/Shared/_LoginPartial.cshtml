@using Microsoft.AspNetCore.Identity
@using Web_Api_Amazon.Entities
using Web_Api_Amazon.Entities;
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            <a class="nav-link text-dark" asp-controller="Account" asp-action="Logout">Logout</a>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class ="nav-link text-dark" asp-action="Entry" asp-controller="Account" asp-route-target="register">Register</a>

        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-action="Entry" asp-controller="Account" asp-route-target="login">Login</a>
        </li>
    }
</ul>
